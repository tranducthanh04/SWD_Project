{
  "info": {
    "name": "ONLINE JOB SEARCHING SYSTEM",
    "_postman_id": "5bbd0aaf-e1eb-4b1b-96b4-ojss-collection",
    "description": "Sample request collection for the Online Job Searching System API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"

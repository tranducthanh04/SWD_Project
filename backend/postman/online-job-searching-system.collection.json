  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Job Seeker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"candidate99\",\n  \"email\": \"candidate99@example.com\",\n  \"fullName\": \"Candidate 99\",\n  \"password\": \"Candidate@123\",\n  \"gender\": \"other\",\n  \"role\": \"jobseeker\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Public Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/jobs?sort=latest&page=1&limit=12",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs"
              ],
              "query": [
                {
                  "key": "sort",
                  "value": "latest"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "12"
                }
              ]
            }
          }
        },
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{enterpriseAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior React Engineer\",\n  \"overview\": \"Lead frontend delivery for hiring platforms.\",\n  \"description\": \"Build modern dashboards and improve candidate experience.\",\n  \"requirements\": [\"React\", \"Tailwind CSS\", \"Testing\"],\n  \"benefits\": [\"Remote\", \"Health insurance\"],\n  \"location\": \"Ho Chi Minh City\",\n  \"salaryMin\": 1500,\n  \"salaryMax\": 2500,\n  \"currency\": \"USD\",\n  \"experienceLevel\": \"Senior\",\n  \"jobType\": \"Full-time\",\n  \"tags\": [\"react\", \"tailwind-css\"],\n  \"applicationDeadline\": \"2026-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Pending Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/jobs/pending",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "jobs",
                "pending"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
